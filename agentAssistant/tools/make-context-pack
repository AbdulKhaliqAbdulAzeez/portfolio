#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  make-context-pack "task description"
  make-context-pack "task description" output-file.md

Creates a compact context-pack.md for Codex using Gemini. The pack includes
project overview, relevant files, summaries, edit points, and risks.
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if ! command -v gemini >/dev/null 2>&1; then
  echo "Error: gemini CLI was not found in PATH." >&2
  exit 127
fi

task="${1:-}"
output="${2:-context-pack.md}"

if [[ -z "$task" ]]; then
  usage >&2
  exit 2
fi

if command -v rg >/dev/null 2>&1; then
  file_list="$(rg --files \
    -g '!build/**' \
    -g '!dist/**' \
    -g '!node_modules/**' \
    -g '!bin/**' \
    -g '!obj/**' \
    | sed -n '1,1500p')"
else
  file_list="$(find . -type f \
    ! -path './build/*' \
    ! -path './dist/*' \
    ! -path './node_modules/*' \
    ! -path './bin/*' \
    ! -path './obj/*' \
    | sed 's#^\./##' \
    | sed -n '1,1500p')"
fi

preview=""
while IFS= read -r file; do
  [[ -f "$file" ]] || continue
  case "$file" in
    *.js|*.ts|*.tsx|*.jsx|*.py|*.go|*.rs|*.java|*.c|*.cpp|*.h|*.hpp|*.sh|*.md|*.txt|*.json|*.yaml|*.yml)
      preview+="
--- FILE: $file ---
$(sed -n '1,220p' "$file")
"
...
## Warnings And Risks
Integration risks, null/state concerns, or tests to verify.

    break
  fi
done <<< "$file_list"

tmp_output="$(mktemp)"

gemini > "$tmp_output" <<EOF
You are a scouting assistant preparing a small context pack for Codex CLI.
Codex will make final code changes, so keep this factual and compact.

Task:
$task

Project file list:
$file_list

Selected file previews:
$preview

Create a Markdown context pack with these sections:
# Context Pack
## Task
## Brief Project Overview
## Relevant Files
For each file: path, why it matters, confidence.
## File Summaries
Short summaries of likely relevant files.
## Key Methods And Classes
Names and why they matter.
## Suggested Edit Locations
Specific files and symbols where Codex should inspect or edit.
## Warnings And Risks
Integration risks, null/state concerns, tests or scenes to verify.
## Suggested Next Commands
Short shell commands Codex can run locally.

Rules:
- Keep the whole pack under about 250 lines.
- Do not invent files. If uncertain, mark confidence Low.
- Prefer exact paths from the file list.
- Do not provide final architecture decisions.
- Do not include large code blocks.
EOF

{
  printf '<!-- Generated by make-context-pack using Gemini CLI. Codex should verify before editing. -->\n\n'
  cat "$tmp_output"
} > "$output"

rm -f "$tmp_output"
echo "Wrote $output"
